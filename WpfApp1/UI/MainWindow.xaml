<Window x:Class="VAFlightTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VAFlightTracker"
        Height="750"
        Width="900">
    
    <Grid Margin="10">

        <!-- MAIN LAYOUT -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT PANEL ================= -->
        <StackPanel Grid.Column="0">

            <!-- NETWORK LOGIN -->
            <Border Padding="15">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Pilot ID"
                               VerticalAlignment="Center"/>

                    <TextBox x:Name="PilotIdTextBox"
                             Grid.Column="1"
                             Height="28"
                             Margin="5,0"/>

                    <TextBlock Text="Password"
                               Grid.Column="3"
                               VerticalAlignment="Center"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Column="4"
                                 Height="28"
                                 Margin="5,0"/>

                </Grid>

            </Border>


            <!-- ================= FLIGHT INFORMATION ================= -->
            <Border Padding="15"
                    Margin="0,15,0,0">

                <StackPanel>

                    <TextBlock Text="Flight Information"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Flight Number -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Flight #"/>
                            <TextBox x:Name="FlightNumberTextBox"
                                     Height="28"/>
                        </StackPanel>

                        <!-- Leg -->
                        <StackPanel Grid.Column="1" Margin="10,0">
                            <TextBlock Text="Leg"/>
                            <TextBox x:Name="LegTextBox"
                                     Height="28"/>
                        </StackPanel>

                        <!-- Aircraft -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Aircraft"/>
                            <ComboBox x:Name="AircraftComboBox"
                                      Height="28">

                                <ComboBoxItem Content="B738"/>
                                <ComboBoxItem Content="B739"/>
                                <ComboBoxItem Content="B752"/>
                                <ComboBoxItem Content="B763"/>
                                <ComboBoxItem Content="B744"/>
                                <ComboBoxItem Content="B77L"/>
                                <ComboBoxItem Content="A320"/>
                                <ComboBoxItem Content="A321"/>
                                <ComboBoxItem Content="A333"/>

                            </ComboBox>
                        </StackPanel>

                    </Grid>

                </StackPanel>

            </Border>


            <!-- ================= FLIGHT PLANNING ================= -->
            <Border Padding="15"
                    Margin="0,15,0,0">

                <StackPanel>

                    <TextBlock Text="Flight Planning"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- DEPARTURE -->
                        <TextBlock Text="Departure"
                        Grid.Row="0"
                        VerticalAlignment="Center"/>

                        <TextBox x:Name="DepartureTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Width="60"
                         Height="25"
                         MaxLength="4"
                         CharacterCasing="Upper"
                         TextChanged="DepartureTextBox_TextChanged" Margin="10,0,190,0"/>

                        <ComboBox x:Name="DepartureComboBox"
                          Grid.Row="0"
                          Grid.Column="1"
                          Width="250"
                          IsEditable="False"
                          SelectionChanged="DepartureComboBox_SelectionChanged" Margin="89,1,-79,34" Grid.RowSpan="2"/>

                        <!-- ARRIVAL -->
                        <TextBlock Text="Arrival"
                       Grid.Row="1"
                       VerticalAlignment="Center"
                       Margin="0,10,0,0"/>

                        <TextBox x:Name="ArrivalTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="10,6,190,4"
                         Width="60"
                         Height="25"
                         MaxLength="4"
                         CharacterCasing="Upper"
                         TextChanged="ArrivalTextBox_TextChanged"/>

                        <ComboBox x:Name="ArrivalComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="89,6,-79,4"
                          Width="250"
                          IsEditable="False"
                          SelectionChanged="ArrivalComboBox_SelectionChanged"/>

                        <!-- ALTERNATE -->
                        <TextBlock Text="Alternate"
                           Grid.Row="2"
                           VerticalAlignment="Center"
                           Margin="0,10,0,0"/>

                        <TextBox x:Name="AlternateTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="10,5,190,5"
                         Width="60"
                         Height="25"
                         MaxLength="4"
                         CharacterCasing="Upper"
                         TextChanged="AlternateTextBox_TextChanged"/>

                        <ComboBox x:Name="AlternateComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="89,6,-79,4"
                          Width="250"
                          IsEditable="False"
                          SelectionChanged="AlternateComboBox_SelectionChanged"/>

                        <!-- PAYLOAD -->
                        <TextBlock Text="Payload (lbs)"
                                   Grid.Row="3"
                                   VerticalAlignment="Center"
                                   Margin="0,10,0,0"/>

                        <TextBox x:Name="PayloadTextBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="5,5,0,5"
                                 Width="120"
                                 Height="25" HorizontalAlignment="Left"/>

                    </Grid>

                    <!-- ROUTE -->
                    <TextBlock Text="Route"
                               Margin="0,15,0,5"/>

                    <TextBox x:Name="RouteTextBox"
                             Height="25"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>

                    <!-- REMARKS -->
                    <TextBlock Text="Remarks"
                               Margin="0,12,0,5"/>

                    <TextBox x:Name="RemarksTextBox"
                             Height="30"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>

                </StackPanel>

            </Border>


            <!-- ================= FLIGHT CONTROL ================= -->
            <Border Padding="15"
                    Margin="0,15,0,0">

                <StackPanel>

                    <TextBlock Text="Flight Control"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="ConnectionStatusText"
                               Text="Disconnected"
                               Foreground="Red"
                               Margin="0,10,0,0"/>

                </StackPanel>

            </Border>


            <!-- ================= FLIGHT PROGRESS ================= -->
            <Border Padding="15"
                    Margin="0,15,0,0">

                <StackPanel>

                    <TextBlock Text="Flight Progress"
                               FontWeight="SemiBold"/>

                    <ProgressBar x:Name="FlightProgressBar"
                                 Height="20"
                                 Margin="0,10,0,0"
                                 Value="0"/>

                </StackPanel>

            </Border>

        </StackPanel>


        <!-- ================= RIGHT PANEL ================= -->
        <StackPanel Grid.Column="1"
                    Margin="15,0,0,0">

            <Border Padding="15">

                <StackPanel>

                    <TextBlock Text="Network Connection"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button x:Name="ConnectButton"
                    Width="120"
                    Height="32"
                    Margin="0,0,0,12"
                    Click="ConnectButton_Click"
                    Content="Connect"/>

                    <TextBlock Text="Network"/>

                    <ComboBox x:Name="NetworkComboBox"
                              Height="28"
                              Width="140"
                              Margin="0,5,0,10">
                        
                    <ComboBoxItem Content="Offline"/>
                    <ComboBoxItem Content="VATSIM"/>
                    <ComboBoxItem Content="IVAO"/>
                    </ComboBox>

                    <Button x:Name="StartFlightButton"
                    Width="120"
                    Height="32"
                    Margin="0,8,0,0"
                    Click="StartFlightButton_Click"
                    Content="Start Flight"/>

                    <TextBox x:Name="DebugTextBox"
                     Height="120"
                     Margin="0,20,0,0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap" TextChanged="DebugTextBox_TextChanged"/>

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>

</Window>